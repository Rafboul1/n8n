      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawOutput = $json.text || $json.output || $json.response || $json.message?.content || Object.values($json)[0] || '';\nconst raw = typeof rawOutput === 'string' ? rawOutput : JSON.stringify(rawOutput);\n\nlet aiOutput;\ntry {\n  const jsonMatches = raw.match(/\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}/g);\n  if (jsonMatches) {\n    const lastJson = jsonMatches[jsonMatches.length - 1];\n    aiOutput = JSON.parse(lastJson);\n  }\n} catch (e) {}\n\n// Si le modèle a wrappé dans {\"output\": {...}}, unwrap\nif (aiOutput && aiOutput.output && typeof aiOutput.output === 'object') {\n  aiOutput = aiOutput.output;\n}\n\n// Fallback si parsing échoué\nif (!aiOutput || typeof aiOutput !== 'object') {\n  return {\n    json: {\n      valid: false,\n      error: 'Parsing IA échoué',\n      category: 'autre',\n      summary: 'Résumé non disponible',\n      sentiment: 'neutre',\n      confidence: 0,\n      action_needed: false,\n      is_invoice: false,\n      invoice_amount: null,\n      invoice_currency: null,\n      invoice_due_date: null,\n      suggested_reply: null\n    }\n  };\n}\n\n// Forcer les booléens\nconst toBool = (val) => {\n  if (typeof val === 'boolean') return val;\n  if (typeof val === 'string') return val.toLowerCase() === 'true';\n  return false;\n};\n\n// Noms de champs flexibles (le modèle change les noms parfois)\nconst category = aiOutput.category ?? aiOutput.classification ?? aiOutput.type ?? 'autre';\nconst summary = aiOutput.summary ?? aiOutput.resume ?? aiOutput.résumé ?? 'Résumé non disponible';\nconst sentiment = aiOutput.sentiment ?? aiOutput.tone ?? aiOutput.mood ?? 'neutre';\nconst rawConfidence = aiOutput.confidence ?? aiOutput.confidence_score ?? aiOutput.score ?? 0.5;\nconst confidence = typeof rawConfidence === 'number' ? rawConfidence : parseFloat(rawConfidence) || 0.5;\nconst actionNeeded = aiOutput.action_needed ?? aiOutput.actionNeeded ?? aiOutput.action ?? false;\nconst isInvoice = aiOutput.is_invoice ?? aiOutput.isInvoice ?? aiOutput.invoice ?? false;\nconst invoiceAmount = aiOutput.invoice_amount ?? aiOutput.amount ?? aiOutput.facture?.amount ?? aiOutput.facture?.montant ?? null;\nconst invoiceCurrency = aiOutput.invoice_currency ?? aiOutput.currency ?? aiOutput.devise ?? aiOutput.facture?.currency ?? aiOutput.facture?.devise ?? null;\nconst invoiceDueDate = aiOutput.invoice_due_date ?? aiOutput.due_date ?? aiOutput.dueDate ?? aiOutput.facture?.due_date ?? aiOutput.facture?.date_echeance ?? null;\nconst suggestedReply = aiOutput.suggested_reply ?? aiOutput.draft_response ?? aiOutput.reply ?? aiOutput.draft ?? null;\n\nconst validCategories = ['spam', 'important', 'newsletter', 'facture', 'action_requise', 'notification', 'personnel', 'autre'];\nconst validSentiments = ['urgent', 'positif', 'neutre', 'negatif'];\n\nreturn {\n  json: {\n    valid: true,\n    category: validCategories.includes(category) ? category : 'autre',\n    summary: String(summary).slice(0, 500),\n    sentiment: validSentiments.includes(sentiment) ? sentiment : 'neutre',\n    confidence: Math.max(0, Math.min(1, confidence)),\n    action_needed: toBool(actionNeeded),\n    is_invoice: toBool(isInvoice),\n    invoice_amount: invoiceAmount,\n    invoice_currency: invoiceCurrency,\n    invoice_due_date: invoiceDueDate,\n    suggested_reply: suggestedReply\n  }\n};"
      },
