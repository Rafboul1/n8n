    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\n\n// Nettoyage du montant\nlet amount = item.invoice_amount;\nif (amount) {\n  // Supprimer symboles de devise et espaces\n  amount = String(amount).replace(/[€$£\\s]/g, '').replace(',', '.');\n  amount = parseFloat(amount);\n  if (isNaN(amount)) amount = null;\n}\n\n// Validation de la date d'échéance\nlet dueDate = item.invoice_due_date;\nif (dueDate) {\n  // Vérifier format YYYY-MM-DD\n  const dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\n  if (!dateRegex.test(dueDate)) {\n    // Essayer de parser des formats alternatifs\n    try {\n      const parsed = new Date(dueDate);\n      if (!isNaN(parsed.getTime())) {\n        dueDate = parsed.toISOString().split('T')[0];\n      } else {\n        dueDate = null;\n      }\n    } catch {\n      dueDate = null;\n    }\n  }\n}\n\nreturn {\n  json: {\n    dateReception: item.dateFormatted,\n    expediteur: item.fromName || item.fromEmail,\n    montant: amount,\n    devise: item.invoice_currency || 'EUR',\n    dateEcheance: dueDate,\n    description: item.summary,\n    statut: 'non_payée',\n    gmailLink: item.gmailLink\n  }\n};"
      },
